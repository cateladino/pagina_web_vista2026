# Cache policy for GoDaddy/Apache
# Goal: show updates quickly after each deploy

<IfModule mod_headers.c>
  # HTML NUNCA se cachea
  <FilesMatch "\.html?$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "-1"
  </FilesMatch>

  # CSS y JS con versioning - Podem reutilizarse cada hora
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, must-revalidate, max-age=3600"
  </FilesMatch>
  
  # Images se cachean 30 días
  <FilesMatch "\.(jpg|jpeg|png|gif|ico|webp|svg)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType text/javascript "access plus 0 seconds"
</IfModule>
